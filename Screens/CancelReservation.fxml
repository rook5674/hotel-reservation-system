<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Screens.CancelReservationController"
            prefWidth="520" prefHeight="400">

    <top>
        <VBox spacing="4" style="-fx-padding: 24 28 12 28;">
            <Label text="Cancel Reservation" styleClass="title-label"/>
            <Label text="Select a reservation to cancel."
                   style="-fx-text-fill: #888888;"/>
        </VBox>
    </top>

    <center>
        <VBox styleClass="card" spacing="14"
              style="-fx-padding: 24 28 24 28;">

            <Label text="Select Reservation"/>
            <ComboBox fx:id="reservationComboBox"
                      promptText="Choose a reservation"
                      maxWidth="Infinity"/>

            <!-- Details box, hidden until selection -->
            <VBox fx:id="detailsBox" spacing="6"
                  style="-fx-padding: 10; -fx-background-color: #0f3460;
                         -fx-background-radius: 6;" visible="false">
                <Label fx:id="detailRoom"    text="Room: —"/>
                <Label fx:id="detailDates"   text="Dates: —"/>
                <Label fx:id="detailNights"  text="Nights: —"/>
                <Label fx:id="detailCost"    text="Total Cost: —"/>
                <Label fx:id="detailStatus"  text="Status: —"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" text=""/>

            <Button text="Cancel This Reservation"
                    styleClass="btn-danger"
                    onAction="#handleCancel"
                    maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>