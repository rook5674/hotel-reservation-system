<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Screens.ReservationHistoryController"
            prefWidth="700" prefHeight="480">

    <top>
        <VBox spacing="4" style="-fx-padding: 24 28 12 28;">
            <Label text="My Reservations" styleClass="title-label"/>
            <Label text="All your past and current bookings."
                   style="-fx-text-fill: #888888;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="12" style="-fx-padding: 0 28 24 28;">

            <HBox spacing="10">
                <ComboBox fx:id="filterComboBox"
                          promptText="Filter by status"/>
                <Button text="Refresh" styleClass="btn-primary"
                        onAction="#handleRefresh"/>
            </HBox>

            <TableView fx:id="reservationTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol"       text="ID"        prefWidth="50"/>
                    <TableColumn fx:id="roomCol"     text="Room"      prefWidth="80"/>
                    <TableColumn fx:id="checkInCol"  text="Check-in"  prefWidth="110"/>
                    <TableColumn fx:id="checkOutCol" text="Check-out" prefWidth="110"/>
                    <TableColumn fx:id="nightsCol"   text="Nights"    prefWidth="70"/>
                    <TableColumn fx:id="costCol"     text="Total"     prefWidth="90"/>
                    <TableColumn fx:id="statusCol"   text="Status"    prefWidth="110"/>
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>