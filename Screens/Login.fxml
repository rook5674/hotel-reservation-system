<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Screens.LoginController"
            prefWidth="1000" prefHeight="650"
            styleClass="retro-root">

    <top>
        <HBox styleClass="retro-topbar">
            <Label text="CSE241 HOTEL TERMINAL" styleClass="retro-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="accessModeLabel" text="ACCESS NODE / LOGIN" styleClass="retro-code"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets top="26" right="26" bottom="26" left="26"/>
            </padding>

            <VBox maxWidth="540" spacing="18" alignment="CENTER" styleClass="retro-card">
                <Label fx:id="loginTitleLabel" text="LOGIN" styleClass="retro-screen-title"/>
                <Label fx:id="loginSubtitleLabel"
                       text="Enter credentials to open the reservation ledger."
                       styleClass="retro-muted"
                       wrapText="true"/>

                <Separator/>

                <GridPane maxWidth="Infinity" styleClass="form-grid">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="34"/>
                        <ColumnConstraints percentWidth="66" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="USERNAME" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="usernameField"
                               promptText="username"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"
                               maxWidth="Infinity"/>

                    <Label text="PASSWORD" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="password"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"
                                   maxWidth="Infinity"/>
                </GridPane>

                <Label fx:id="statusLabel" text="" styleClass="retro-status" wrapText="true"/>

                <HBox spacing="10" alignment="CENTER" maxWidth="Infinity">
                    <Button text="LOGIN"
                            onAction="#handleLogin"
                            styleClass="primary-button"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>

                    <Button fx:id="registerButton"
                            text="REGISTER"
                            onAction="#handleRegister"
                            styleClass="secondary-button"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER" maxWidth="Infinity">
                    <Button text="FORGOT USERNAME"
                            onAction="#handleForgotUsername"
                            styleClass="secondary-button"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>

                    <Button text="CHANGE ACCESS TYPE"
                            onAction="#handleBackToRoleSelection"
                            styleClass="secondary-button"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
