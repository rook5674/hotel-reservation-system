<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AmenityManagementController"
      spacing="20"
      prefWidth="900"
      prefHeight="560"
      stylesheets="@../styles/style.css"
      styleClass="root-pane">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Left: Form -->
    <VBox spacing="10" styleClass="card-pane" prefWidth="380">

        <Label text="Amenity Management" styleClass="title-label"/>

        <Label text="Amenity ID:" styleClass="field-label"/>
        <TextField fx:id="idField" promptText="Enter amenity ID"/>

        <Label text="Amenity Name:" styleClass="field-label"/>
        <TextField fx:id="nameField" promptText="Enter amenity name"/>

        <Label text="Amenity Type:" styleClass="field-label"/>
        <ComboBox fx:id="typeComboBox" promptText="Select type" maxWidth="Infinity"/>

        <HBox spacing="10">
            <Button text="Create" onAction="#createAmenity" styleClass="primary-button"/>
            <Button text="Update Name" onAction="#updateAmenityName" styleClass="secondary-button"/>
        </HBox>

        <HBox spacing="10">
            <Button text="Delete" onAction="#deleteAmenity" styleClass="danger-button"/>
            <Button text="Clear" onAction="#clearFields" styleClass="secondary-button"/>
        </HBox>

        <Label fx:id="feedbackLabel" text="" wrapText="true" styleClass="feedback-label"/>

    </VBox>

    <!-- Right: List -->
    <VBox spacing="10" styleClass="card-pane" prefWidth="480">

        <Label text="All Amenities" styleClass="section-label"/>

        <ListView fx:id="amenityListView" prefHeight="440"/>

        <Button text="Refresh" onAction="#readAmenity" styleClass="secondary-button"/>

    </VBox>

</HBox>